# Facebook App credentials
FACEBOOK_APP_ID=your_app_id
FACEBOOK_APP_SECRET=your_app_secret

# Used for GET webhook verification challenge
FACEBOOK_WEBHOOK_VERIFY_TOKEN=change_this_to_long_random_string

# Page access token used for Send API (POST /me/messages)
FACEBOOK_PAGE_ACCESS_TOKEN=your_page_access_token

# Public app URL where webhook route is reachable
# Example: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
